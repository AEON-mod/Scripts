{
    "title": "Touchpad Toggle — Karabiner-Elements Complex Rule",
    "rules": [
        {
            "description": "Super+Ctrl+L → Toggle Touchpad (runs touchpad-toggle.sh)",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "l",
                        "modifiers": {
                            "mandatory": [
                                "left_command",
                                "left_control"
                            ],
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "shell_command": "$HOME/.local/bin/touchpad-toggle"
                        }
                    ]
                }
            ]
        }
    ]
}
